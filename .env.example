# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.

# Google Gemini (get from Google AI Studio: aistudio.google.com)
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps + Places API (get from Google Cloud Console)
# Enable: Maps JavaScript API, Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps JavaScript key for frontend map (safe to expose in browser,
# but still restrict by allowed website referrers).
# Frontend fetches this from /api/config/public at runtime.
GOOGLE_MAPS_JS_API_KEY=your_browser_maps_js_api_key_here
